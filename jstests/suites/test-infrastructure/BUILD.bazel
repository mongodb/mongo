## Need to update a resmoke_suite_test?
# Explanations of fields of the resmoke_suite_test rule are in bazel/resmoke/README.md.
# In addition, certain `tags` and `target_compatible_with` are used to control which
# tests are run in which CI tasks. Common cases are enumerated in jstests/suites/README.md.
#
# To run a suite:
# bazel test //jstests/suites/query-execution:core
#
# To run a single test in a suite:
# bazel test //jstests/suites/query-execution:core --test_sharding_strategy=disabled --test_arg=jstests/some_test.js
#
# To run outside the bazel sandbox, you may still use:
# python buildscripts/resmoke.py run --suites=core

load("//bazel/resmoke:resmoke.bzl", "resmoke_suite_test")

[
    resmoke_suite_test(
        name = suite_name,
        config = "//buildscripts/resmokeconfig:matrix_suites/generated_suites/{}.yml".format(suite_name),
        multiversion_deps = [
            "//bazel/resmoke/multiversion:{}".format(multiversion),
        ],
        resmoke_args = [
            "--runNoFeatureFlagTests",
        ],
        tags = [
            "ci-default",
            "multiversion",
            "multiversion_sanity_check",
        ],
        deps = [
            "//src/mongo/db:mongod",
            "//src/mongo/shell:mongo",
        ],
    )
    for suite_name, multiversion in {
        "multiversion_sanity_check_last_continuous_new_new_old": "last-continuous",
        "multiversion_sanity_check_last_continuous_old_new_new": "last-continuous",
        "multiversion_sanity_check_last_continuous_new_old_new": "last-continuous",
        "multiversion_sanity_check_last_lts_new_new_old": "last-lts",
        "multiversion_sanity_check_last_lts_new_old_new": "last-lts",
        "multiversion_sanity_check_last_lts_old_new_new": "last-lts",
    }.items()
]

resmoke_suite_test(
    name = "resmoke_end2end_tests",
    config = "//buildscripts/resmokeconfig:suites/resmoke_end2end_tests.yml",
    shard_count = 2,
    tags = [
        "ci-default",
        "incompatible_with_bazel_remote_test",  # Makes many assumptions about paths that are incompatible with sandboxing.
    ],
    deps = [
        "//src/mongo/db:mongod",
        "//src/mongo/shell:mongo",
    ],
)

resmoke_suite_test(
    name = "unittest_shell_hang_analyzer",
    config = "//buildscripts/resmokeconfig:suites/unittest_shell_hang_analyzer.yml",
    tags = [
        "ci-release-critical",
        "incompatible_with_bazel_remote_test",  # Expects a system python to be available: `python ./buildscripts/resmoke.py hang-analyzer ...` Unable to start program python: No such file or directory
        "requires_compile_variant",
        "requires_execution_on_windows_patch_build",
    ],
    deps = [
        "//src/mongo/db:mongod",
        "//src/mongo/s:mongos",
        "//src/mongo/shell:mongo",
    ],
)

resmoke_suite_test(
    name = "slow1",
    config = "//buildscripts/resmokeconfig:suites/slow1.yml",
    shard_count = 4,
    tags = [
        "ci-release-critical",
        "misc_js",
        "non_win_dbg",
        "suggested_excluding_required__for_devprod_mitigation_only",
    ],
    deps = [
        "//src/mongo/db:mongod",
        "//src/mongo/shell:mongo",
    ],
)
