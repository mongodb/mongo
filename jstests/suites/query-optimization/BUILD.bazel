resmoke_suite_test(
    name = "query_correctness_manual_test",
    config = "//buildscripts/resmokeconfig:suites/query_tester_manual_test.yml",
    tags = [
        "ci-default",
        "incompatible_with_bazel_remote_test",  # Tests fail with "Permission denied": Failed to open file
        "requires_all_feature_flags",
    ],
    target_compatible_with = select({
        "//bazel/config:asan_enabled": ["@platforms//:incompatible"],
        "//bazel/config:tsan_enabled": ["@platforms//:incompatible"],
        "//bazel/config:ubsan_enabled": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    # The query_tester test kind treats each directory under manual_tests/ as a
    # single test case. srcs auto-derive to those directories; directory
    # granularity writes each as a test while still tracking its multiple files as inputs.
    test_root_granularity = "directory",
    deps = [
        "//src/mongo/db:mongod",
        "//src/mongo/db/query/query_tester:mongotest",
        "//src/mongo/shell:mongo",
    ],
)

