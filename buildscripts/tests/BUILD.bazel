        "test_sync_repo_with_copybara.py",
    ],
    data = [
        "//buildscripts/copybara:copybara_config_files",
        "//etc:evergreen_yml_components/copybara/copybara_gen.yml",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//buildscripts/copybara",
    ],
)

