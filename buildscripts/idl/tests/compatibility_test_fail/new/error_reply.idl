types:
    string:
        bson_serialization_type: string
        description: "A BSON UTF-8 string"
        cpp_type: "std::string"
        deserializer: "mongo::BSONElement::str"
        is_view: false

structs:
    ErrorReply:
        description: "Error Reply struct should fail"
        strict: false
        fields:
            errorLabels:
                type: StructType
                stability: stable

    StructType:
        description:
            "This struct contains a field that is non-optional in the old
            command and optional in the new command."
        fields:
            structField:
                type: string
                optional: true
                stability: stable
