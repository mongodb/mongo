#pragma once

// List of possible SSL providers
#define MONGO_CONFIG_SSL_PROVIDER_OPENSSL 1
#define MONGO_CONFIG_SSL_PROVIDER_WINDOWS 2
#define MONGO_CONFIG_SSL_PROVIDER_APPLE 3

// Disabling clang-format since it changes `@var@` to `@var @` which would break the template.
//
// clang-format off

// Define altivec vec_vbpermq output index
@mongo_config_altivec_vec_vbpermq_output_index@

// Define if building a debug build
@mongo_config_debug_build@

// Defined if execinfo.h and backtrace are available
@mongo_config_have_execinfo_backtrace@

// Defined if explicit_bzero is available
@mongo_config_have_explicit_bzero@

// Defined if OpenSSL has the FIPS_mode_set function
@mongo_config_have_fips_mode_set@

// Defined if unitstd.h is available
@mongo_config_have_header_unistd_h@

// Defined if memset_s is available
@mongo_config_have_memset_s@

// Defined if a POSIX monotonic clock is available
@mongo_config_have_posix_monotonic_clock@

// Defined if pthread.h and pthread_setname_np are available
@mongo_config_have_pthread_setname_np@

// Defined if OpenSSL has `EC_KEY_new_by_curve_name` and the `NID_X9_62_prime256v1` curve defined
@mongo_config_have_ssl_ec_key_new@

// Defined if OpenSSL has `SSL_CTX_set_ecdh_auto` and `SSL_set_ecdh_auto`
@mongo_config_have_ssl_set_ecdh_auto@

// Defined if strnlen is available
@mongo_config_have_strnlen@

// A number, if we have some extended alignment ability
@mongo_config_max_extended_alignment@

// defined if OCSP Stapling is enabled
@mongo_config_ocsp_stapling_enabled@

// Defined if building an optimized build
@mongo_config_optimized_build@

// Defined if OpenSSL has SEQUENCE_ANY
@mongo_config_have_asn1_any_definitions@

// Defined if SSL support is enabled with chosen ssl provider
@mongo_config_ssl_provider@

// Defined if SSL support is enabled
@mongo_config_ssl@

// Defined if USDT probes are enabled
@mongo_config_usdt_enabled@

// Set to which provider defines USDT
@mongo_config_usdt_provider@

// Defined if using libunwind.
@mongo_config_use_libunwind@

// Defined if raw latches are enabled
@mongo_config_use_raw_latches@

// Defined if WiredTiger storage engine is enabled
@mongo_config_wiredtiger_enabled@

// Defined if grpc support is enabled
@mongo_config_grpc@

// Defined if TLS connection handoff support is enabled
@mongo_config_connection_handoff@

// Defined if the glibc rseq header is present
@mongo_config_glibc_rseq@

// Defined if using the tcmalloc-google memory allocator
@mongo_config_tcmalloc_google@

// Defined if using the tcmalloc-gperf memory allocator
@mongo_config_tcmalloc_gperf@

// Defined if using tracing profiler stats collection
@mongo_config_use_tracing_profiler@

// Defined if the build includes stream processing module
@mongo_config_streams@

// Defined if the build includes OpenTelemetry
@mongo_config_otel@

// Defined if the build includes disaggregated storage
@mongo_config_disagg_storage@

// Defined if using prettier dev stacktraces
@mongo_config_dev_stacktrace@

// Defined if the build is for antithesis
@mongo_config_antithesis@

// Defined if the build is in extensions signature verification secure mode
@mongo_config_extensions_signature_verification_secure@

    // clang-format on
