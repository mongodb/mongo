projection_test
test
projection_test.coll as coll

// ---------------------------------------------------------------
// $project inclusion
// ---------------------------------------------------------------
0
:sortFull {aggregate: "coll", pipeline: [{$project: {a: 1, b: 1}}], cursor: {}}
[
{"_id":1,"a":1,"b":2},
{"_id":2,"a":4,"b":5},
{"_id":3,"a":7,"b":8}
]

// ---------------------------------------------------------------
// $project inclusion nested
// ---------------------------------------------------------------
1
:sortFull {aggregate: "coll", pipeline: [{$project: {"o.p": 1, "oo.o.p": 1}}], cursor: {}}
[
{"_id":1,"o":{"p":1}},
{"_id":2,"o":{"p":4},"oo":{"o":{"p":4}}},
{"_id":3,"o":{"p":7}}
]

// ---------------------------------------------------------------
// $project exclusion
// ---------------------------------------------------------------
2
:sortFull {aggregate: "coll", pipeline: [{$project: {a: 0, b: 0}}], cursor: {}}
[
{"_id":1,"c":3,"o":{"p":1,"q":2,"r":3}},
{"_id":2,"c":6,"o":{"p":4,"q":5,"r":6},"oo":{"o":{"p":4,"q":5,"r":6}}},
{"_id":3,"o":{"p":7,"q":8}}
]

// ---------------------------------------------------------------
// $project exclusion nested
// ---------------------------------------------------------------
3
:sortFull {aggregate: "coll", pipeline: [{$project: {"o.p": 0, "oo.o.p": 0}}], cursor: {}}
[
{"_id":1,"a":1,"b":2,"c":3,"o":{"q":2,"r":3}},
{"_id":2,"a":4,"b":5,"c":6,"o":{"q":5,"r":6},"oo":{"o":{"q":5,"r":6}}},
{"_id":3,"a":7,"b":8,"o":{"q":8}}
]

// ---------------------------------------------------------------
// $project exclusion inclusion
// ---------------------------------------------------------------
4
:sortFull {aggregate: "coll", pipeline: [{$project: {a: 0}}, {$project: {b: 1}}], cursor: {}}
[
{"_id":1,"b":2},
{"_id":2,"b":5},
{"_id":3,"b":8}
]

// ---------------------------------------------------------------
// $project exclusion multiple
// ---------------------------------------------------------------
5
:sortFull {aggregate: "coll", pipeline: [{$project: {a: 0}}, {$project: {b: 0}}], cursor: {}}
[
{"_id":1,"c":3,"o":{"p":1,"q":2,"r":3}},
{"_id":2,"c":6,"o":{"p":4,"q":5,"r":6},"oo":{"o":{"p":4,"q":5,"r":6}}},
{"_id":3,"o":{"p":7,"q":8}}
]

// ---------------------------------------------------------------
// $project expression
// ---------------------------------------------------------------
6
:sortFull {aggregate: "coll", pipeline: [{$project: {d: {$add: ["$a", "$b", "$c"]}}}], cursor: {}}
[
{"_id":1,"d":6},
{"_id":2,"d":15},
{"_id":3,"d":null}
]

// ---------------------------------------------------------------
// $addFields expression
// ---------------------------------------------------------------
7
:sortFull {aggregate: "coll", pipeline: [{$addFields: {d: {$add: ["$a", "$b", "$c"]}}}], cursor: {}}
[
{"_id":1,"a":1,"b":2,"c":3,"d":6,"o":{"p":1,"q":2,"r":3}},
{"_id":2,"a":4,"b":5,"c":6,"d":15,"o":{"p":4,"q":5,"r":6},"oo":{"o":{"p":4,"q":5,"r":6}}},
{"_id":3,"a":7,"b":8,"d":null,"o":{"p":7,"q":8}}
]

// ---------------------------------------------------------------
// $replaceRoot
// ---------------------------------------------------------------
8
:sortFull {aggregate: "coll", pipeline: [{$replaceRoot: {newRoot: "$o"}}], cursor: {}}
[
{"p":1,"q":2,"r":3},
{"p":4,"q":5,"r":6},
{"p":7,"q":8}
]
