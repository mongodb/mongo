    deps = [
        ":key",
        ":rate_limiting",
        "//src/mongo/db:api_parameters",
        "//src/mongo/db:commands",
        "//src/mongo/util:buildinfo",
    ],
)

mongo_cc_library(
    name = "key",
    srcs = [
        "key.cpp",
    ],
