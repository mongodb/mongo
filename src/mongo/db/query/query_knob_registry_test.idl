global:
    cpp_namespace: "mongo"
    cpp_includes:
        - "mongo/platform/atomic_word.h"

server_parameters:
    synthIntPqs:
        set_at: [startup, runtime]
        description: "Synthetic int PQS knob for QueryKnobRegistry tests."
        cpp_vartype: AtomicWord<int>
        cpp_varname: gSynthIntPqs
        default: 0
        redact: false
        annotations:
            query_knob:
                wire_name: synthIntPqsWire
                pqs_settable: true
                fcv:
                    min: "9.0"

    synthBoolPqs:
        set_at: [startup, runtime]
        description: "Synthetic bool PQS knob for QueryKnobRegistry tests."
        cpp_vartype: AtomicWord<bool>
        cpp_varname: gSynthBoolPqs
        default: false
        redact: false
        annotations:
            query_knob:
                wire_name: synthBoolPqsWire
                pqs_settable: true
                fcv:
                    min: "9.0"

    synthLongNonPqs:
        set_at: [startup, runtime]
        description: "Synthetic non-PQS long knob for QueryKnobRegistry tests."
        cpp_vartype: AtomicWord<long long>
        cpp_varname: gSynthLongNonPqs
        default: 0
        redact: false
        annotations:
            query_knob:
                wire_name: synthLongNonPqsWire

    synthDoublePlainParam:
        set_at: [startup, runtime]
        description: "Control: plain ServerParameter with no query_knob annotation."
        cpp_vartype: AtomicWord<double>
        cpp_varname: gSynthDoublePlainParam
        default: 0.0
        redact: false
