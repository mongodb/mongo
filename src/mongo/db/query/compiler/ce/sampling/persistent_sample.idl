global:
    cpp_namespace: "mongo::ce"
    mod_visibility: private

imports:
    - "mongo/db/basic_types.idl"

enums:
    SamplingTechnique:
        description: "The method used to generate the sample."
        type: string
        values:
            kRandom: "random"
            kChunk: "chunk"
            kFullCollScan: "fullCollScan"
            kSeqScan: "seqScan"
            kStrides: "strides"

structs:
    PersistentSampleId:
        description: >-
            Structured _id for a persistent-sample document, holding the identity fields that
            key a sample.
        strict: true
        fields:
            schemaVersion:
                type: int
                validator: {gte: 1}
            collectionUuid:
                type: uuid
            samplingMethod:
                type: SamplingTechnique
            sampleSize:
                type: long
                validator: {gt: 0}
            numChunks:
                type: int
                optional: true
                validator: {gt: 0}

    PersistentSampleDoc:
        description: >-
            On-disk document stored in <db>.system.stats.samples for a persisted CE sample.
            Populated by the analyze command and consumed by the sampling estimator.
        strict: true
        fields:
            _id:
                type: PersistentSampleId
            schemaVersion:
                type: int
                validator: {gte: 1}
            collectionUuid:
                type: string
            samplingMethod:
                type: SamplingTechnique
            sampleSize:
                type: long
                validator: {gt: 0}
            numChunks:
                type: int
                optional: true
                validator: {gt: 0}
            createdAt:
                type: date
            # `object` (view), not `object_owned` (per-entry getOwned()): a sample carries
            # 384–2000 docs that the estimator iterates densely. Keeping them all in one shared
            # buffer (via post-parse `shareOwnershipWith` in `parsePersistentSample`) avoids
            # 2k mallocs + memcpys per parse and keeps the docs contiguous in memory for
            # cache-friendly scanning.
            docs:
                type: array<object>
