global:
    mod_visibility: private
    cpp_namespace: "mongo"

imports:
    - "mongo/db/pipeline/value.idl"
    - "mongo/db/basic_types.idl"

structs:
    ReplaceRootSpec:
        description: $replaceRoot aggregation stage
        strict: true
        fields:
            newRoot:
                description: The expression to use to compute the new root of this stage, e.g. '$subObject'
                type: Value
