global:
    cpp_namespace: "mongo"
    cpp_includes:
        - "mongo/db/commands/test_commands_enabled.h"

server_parameters:
    enableTestCommands:
        description: "Enable test commands"
        set_at: startup
        cpp_vartype: bool
        cpp_varname: gEnableTestCommands
        on_update: "onUpdateTestCommandsEnabled"
        default: false
        redact: false
