# Feature flag for FTDC.

global:
    mod_visibility: private
    cpp_namespace: "mongo::feature_flags"

imports:
    - "mongo/db/basic_types.idl"

feature_flags:
    featureFlagGaplessFTDC:
        description: "Feature flag to enable gapless FTDC."
        cpp_varname: gFeatureFlagGaplessFTDC
        default: false
        fcv_gated: false
