global:
    cpp_namespace: "mongo::replicated_fast_count"

server_parameters:
    replicatedFastCountMaxOplogScanLagSecs:
        description: >-
            When no persisted valid-as-of timestamp exists, the maximum acceptable lag in
            seconds between the oldest oplog entry and the last applied oplog entry before the
            fast count catch-up oplog scan is skipped. If the lag exceeds this value, the fast
            count system seeds from the last applied oplog entry and skips the catch-up scan to
            avoid blocking startup and keep the persisted valid-as-of timestamp advancing, at the
            cost of potentially inaccurate size and count.
        set_at: [startup, runtime]
        cpp_vartype: "Atomic<int>"
        cpp_varname: gReplicatedFastCountMaxOplogScanLagSecs
        default: 3600
        validator: {gt: 0}
        redact: false
