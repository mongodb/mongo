# Defines the singleton document stored in config.maxKeyZoneScanState. The document
# tracks the result of the per-primary-stepup MaxKey zone inventory scan run by the
# config-server's per-stepup scan service. The collection is replicated within the
# config-server replica set.

global:
    cpp_namespace: "mongo"
    mod_visibility: private

imports:
    - "mongo/db/basic_types.idl"

structs:
    maxKeyZoneScanState:
        description:
            "Singleton state document for the MaxKey zone detection scan. Lives in
            config.maxKeyZoneScanState on the config server, replicated within the
            config-server replica set."
        strict: false
        fields:
            _id:
                type: string
                description: "Fixed singleton key for this state document."
                default: '"scanState"'
            scanStartedAt:
                type: date
                description: "Wallclock time when the scan started on the current primary."
            scanCompletedAt:
                type: date
                description:
                    "Wallclock time when the scan finished. Set only when the scan ran
                    to completion on the current primary; absent if the scan was abandoned."
                optional: true
            foundBuggyZone:
                type: bool
                description:
                    "True if any config.tags entry was found whose upper bound matches the
                    MaxKey zone fingerprint (compound shard key with trailing MinKey fields
                    that the user almost certainly intended as MaxKey)."
            alertEmitted:
                type: bool
                description:
                    "Gates the one-shot WARNING log emitted when foundBuggyZone transitions
                    to true. Replicated so new primaries do not re-alert for an already
                    surfaced finding."
            binaryVersionAtScan:
                type: string
                description: "Server binary version that performed the scan."
                optional: true
            fcvAtScan:
                type: string
                description: "Feature compatibility version at the time of the scan."
                optional: true
