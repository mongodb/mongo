global:
    mod_visibility: private
    cpp_namespace: "mongo"

imports:
    - "mongo/db/shard_role/ddl/coll_mod.idl"
    - "mongo/db/basic_types.idl"

commands:
    _configsvrCollMod:
        command_name: _configsvrCollMod
        cpp_name: ConfigsvrCollMod
        description: "Internal command sent to config server to update routing related information"
        strict: false
        api_version: ""
        namespace: concatenate_with_db
        fields:
            collModRequest:
                type: CollModRequest
                description: "Initial collMod request"

    _shardsvrCollModParticipant:
        command_name: _shardsvrCollModParticipant
        cpp_name: ShardsvrCollModParticipant
        description: "Internal command sent to all shards to implement collMod locally"
        strict: false
        api_version: ""
        namespace: concatenate_with_db
        fields:
            collModRequest:
                type: CollModRequest
                description: "Initial collMod request"
            needsUnblock:
                type: optionalBool
                description: "If needs to refresh the shard filtering information and unblock CRUD operations"
            performViewChange:
                type: optionalBool
                description: "Whether should perform view catalog change, set only for commands sent to the primary shard"
            clearCollMetadata:
                type: optionalBool
                description: >-
                    If true, the filtering collection metadata will be cleared when releasing the
                    critical section. When the shard is collection authoritative, the coordinator
                    sets this to false because the commit phase updates the shard catalog with
                    current information.
        reply_type: CollModReply
