    deps = [
        ":trace_settings",
        ":tracing_initialization_impl",
        "//src/mongo/db:server_base",
        "//src/mongo/unittest:server_parameter_guard",
        "//src/third_party/opentelemetry-cpp/api",
        "//src/third_party/opentelemetry-cpp/sdk/src/trace",
    ],
