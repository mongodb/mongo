mongo_cc_library(
    name = "traces_test_util",
    srcs = [
        "traces_test_util.cpp",
    ],
    hdrs = [
        "traces_test_util.h",
    ],
    deps = [
        "//src/mongo:base",
        "//src/mongo/otel:otel_base",
        "//src/mongo/otel/traces/span:span_names",
