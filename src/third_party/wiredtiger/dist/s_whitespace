#!/bin/bash

# Single space, newline at the end of file, and remove trailing whitespace from source files.
# Also reject tab characters used for indentation (spaces only).
. `dirname -- ${BASH_SOURCE[0]}`/common_functions.sh
setup_trap
cd_top
use_pygrep
check_fast_mode_flag

# Files imported from third-party sources that keep their original tab indentation.
# They are exempt from the tab-indentation check.
tab_indent_exceptions="\
src/checksum/zseries/vx-insn.h \
src/include/bitstring_inline.h \
src/include/queue.h \
src/support/hash_city.c"

# Clear lines that only contain whitespace, compress multiple empty lines
# into a single line, discard trailing empty lines.
# Add a newline to the end of the file if there is not one.
whitespace()
{
    ! head $1 | grep -q 'automatically generated by SWIG' || return
    if [[ "$1" == *.py ]]; then
        # Special handling for Python, which allows multiple empty lines.
        cat $1 | sed -e 's/[[:space:]]*$//' > $t
        test "$(tail -c 1 "$1" | wc -l)" -eq 0 && echo >> $t
    else
        # All other file types.
        (cat $1 && echo) | sed -e 's/[[:space:]]*$//' | \
            cat -s | \
            sed -e '${' -e '/^$/d' -e '}' > $t
    fi
    cmp $t $1 > /dev/null 2>&1 || (echo "$1" && cp $t $1)
}

# Report lines that use a tab in their leading indentation. Makefiles are exempt
# because make requires tab-indented recipe lines.
check_tab_indent()
{
    case "$1" in
    *Makefile*) return;;
    esac
    ! head $1 | grep -q 'automatically generated by SWIG' || return
    local x
    for x in $tab_indent_exceptions; do
        [[ "$1" == "$x" ]] && return
    done
    LC_ALL=C awk 'BEGIN{re="^ *\t"} $0 ~ re {printf "%s:%d: tab in indentation\n", FILENAME, FNR}' "$1"
}

# Parallel execution: if it's the main onvocation of the script, collect the file names
# to process and run them in subprocesses.
is_main_run && {
    find bench dist examples ext src test tools/checksum_bitflip cmake lang CMakeLists.txt \
        -name '*.[ch]' -o \
        -name '*.cpp' -o \
        -name '*.i' -o \
        -name '*.dox' -o \
        -name '*.in' -o \
        -name '*.py' -o \
        -name '*.sh' -o \
        -name '*.yaml' -o \
        -name '*.yml' -o \
        -name '*.cmake' -o \
        -name 'CMakeLists.txt' -o \
        -name 's_*' -o \
        -name 'CONFIG.*' -o \
        -name 'Makefile.am' | \
        $FGREP -v \
            -e 'Makefile.in' \
            -e 'checksum/power8' \
            -e '3rdparty' \
            -e 'docs/tools' \
            -e 'log/log_auto' \
    | do_in_parallel
    exit $?
}

# A list of files provided: process them one by one.

for f in "$@"; do
    whitespace $f
    check_tab_indent $f
done

exit 0
