# bzip2 - A high-quality data compression library
# License: BSD-like (bzip2 license)
# https://sourceware.org/bzip2/

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "bzip2",
    srcs = [
        "dist/blocksort.c",
        "dist/bzlib.c",
        "dist/compress.c",
        "dist/crctable.c",
        "dist/decompress.c",
        "dist/huffman.c",
        "dist/randtable.c",
    ],
    hdrs = [
        "dist/bzlib.h",
        "dist/bzlib_private.h",
    ],
    copts = select({
        "//bazel/config:compiler_type_clang": [
            "-Wno-implicit-fallthrough",
            "-Wno-unused-but-set-variable",
        ],
        "//bazel/config:compiler_type_gcc": [
            "-Wno-implicit-fallthrough",
            "-Wno-unused-but-set-variable",
        ],
        "//conditions:default": [],
    }),
    includes = ["dist"],
)
