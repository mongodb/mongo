# RNP - A high performance C++ OpenPGP library
# License: BSD-2-Clause
# https://github.com/rnpgp/rnp
#
# NOTE: RNP is only supported on Linux platforms with OpenSSL.

package(default_visibility = ["//visibility:public"])

# Platform restriction for all RNP targets (Linux only, exclude AL2 - OpenSSL 1.1.0+ required)
_LINUX_ONLY = select({
    "@platforms//os:linux": [],
    "//conditions:default": ["@platforms//:incompatible"],
})

_NOT_AL2 = select({
    "//bazel/platforms:amazon_linux_2": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

_RNP_PLATFORM = _LINUX_ONLY + _NOT_AL2

# libsexpp - S-expressions parsing library (submodule of RNP)
# Exclude sexp-main.cpp: it is a standalone CLI with its own main(). Including it
# would cause multiple-definition or wrong-entry-point when linked into tests (e.g.
# db_pipeline_test) that pass test args like --showEachTest to the process.
cc_library(
    name = "sexpp",
    srcs = glob(
        ["dist/src/libsexpp/src/*.cpp"],
        exclude = ["dist/src/libsexpp/src/sexp-main.cpp"],
    ),
    hdrs = glob(["dist/src/libsexpp/include/**/*.h"]),
    copts = [
        "-Wno-unused-parameter",
    ],
    includes = ["dist/src/libsexpp/include"],
    target_compatible_with = _RNP_PLATFORM,
    visibility = ["//visibility:private"],
)

# Common utilities
cc_library(
    name = "rnp_common",
    srcs = glob([
        "dist/src/common/*.cpp",
    ]),
    hdrs = glob([
        "dist/src/common/*.h",
    ]),
    copts = [
        "-Wno-unused-parameter",
        "-Wno-unused-exception-parameter",
    ],
    includes = ["dist/src/common"],
    target_compatible_with = _RNP_PLATFORM,
    visibility = ["//visibility:private"],
    deps = [
        ":rnp_generated_headers",
    ],
)

# librepgp - PGP packet handling
cc_library(
    name = "rnp_librepgp",
    srcs = glob([
        "dist/src/librepgp/*.cpp",
    ]),
    hdrs = glob([
        "dist/src/librepgp/*.h",
    ]),
    copts = [
        "-Wno-unused-parameter",
        "-Wno-unused-exception-parameter",
        "-Wno-sign-compare",
    ],
    includes = [
        "dist/src",
        "dist/src/librepgp",
    ],
    target_compatible_with = _RNP_PLATFORM,
    visibility = ["//visibility:private"],
    deps = [
        ":rnp_common",
        ":rnp_lib_headers",
        "//src/third_party/bzip2",
        "//src/third_party/json-c:json_c",
        "@zlib",
    ],
)

# librekey - Key store handling
cc_library(
    name = "rnp_librekey",
    srcs = glob([
        "dist/src/librekey/*.cpp",
    ]),
    hdrs = glob([
        "dist/src/librekey/*.h",
        "dist/src/librekey/*.hpp",
    ]),
    copts = [
        "-Wno-unused-parameter",
    ],
    includes = [
        "dist/src",
        "dist/src/librekey",
    ],
    target_compatible_with = _RNP_PLATFORM,
    visibility = ["//visibility:private"],
    deps = [
        ":rnp_common",
        ":rnp_lib_headers",
        ":rnp_librepgp",
        ":sexpp",
    ],
)

# Generated headers from CMake configure
cc_library(
    name = "rnp_generated_headers",
    hdrs = [
        "dist/build/rnp/rnp_export.h",
        "dist/build/src/lib/config.h",
        "dist/build/src/lib/version.h",
    ],
    includes = [
        "dist/build",
        "dist/build/src/lib",
    ],
    target_compatible_with = _RNP_PLATFORM,
    visibility = ["//visibility:private"],
)

# Public headers
cc_library(
    name = "rnp_public_headers",
    hdrs = glob(["dist/include/**/*.h"]),
    includes = ["dist/include"],
    target_compatible_with = _RNP_PLATFORM,
    visibility = ["//visibility:private"],
)

# Internal library headers (needed by librepgp/librekey)
cc_library(
    name = "rnp_lib_headers",
    hdrs = glob([
        "dist/src/lib/*.h",
        "dist/src/lib/*.hpp",
        "dist/src/lib/crypto/*.h",
        "dist/src/lib/crypto/*.hpp",
        "dist/src/lib/crypto/sha1cd/*.h",
    ]),
    includes = [
        "dist/src",
        "dist/src/lib",
        "dist/src/lib/crypto",
        "dist/src/lib/crypto/sha1cd",
    ],
    target_compatible_with = _RNP_PLATFORM,
    visibility = ["//visibility:private"],
    deps = [
        ":rnp_generated_headers",
        ":rnp_public_headers",
    ],
)

# Main RNP library
cc_library(
    name = "rnp",
    srcs = glob(["dist/src/lib/*.cpp"]) + [
        # OpenSSL crypto backend sources (from CMakeLists.txt CRYPTO_BACKEND_OPENSSL section)
        "dist/src/lib/crypto/dsa_common.cpp",
        "dist/src/lib/crypto/dsa_ossl.cpp",
        "dist/src/lib/crypto/ec_curves.cpp",
        "dist/src/lib/crypto/ec_ossl.cpp",
        "dist/src/lib/crypto/ecdh_utils.cpp",
        "dist/src/lib/crypto/ecdh_ossl.cpp",
        "dist/src/lib/crypto/ecdsa_ossl.cpp",
        "dist/src/lib/crypto/eddsa_ossl.cpp",
        "dist/src/lib/crypto/dl_ossl.cpp",
        "dist/src/lib/crypto/elgamal_ossl.cpp",
        "dist/src/lib/crypto/hash_common.cpp",
        "dist/src/lib/crypto/hash_ossl.cpp",
        "dist/src/lib/crypto/hash_crc24.cpp",
        "dist/src/lib/crypto/hash_sha1cd.cpp",
        "dist/src/lib/crypto/mpi.cpp",
        "dist/src/lib/crypto/rng_ossl.cpp",
        "dist/src/lib/crypto/rsa_ossl.cpp",
        "dist/src/lib/crypto/s2k.cpp",
        "dist/src/lib/crypto/s2k_ossl.cpp",
        "dist/src/lib/crypto/symmetric_common.cpp",
        "dist/src/lib/crypto/symmetric_ossl.cpp",
        "dist/src/lib/crypto/signatures.cpp",
        "dist/src/lib/crypto/mem_ossl.cpp",
        "dist/src/lib/crypto/cipher.cpp",
        "dist/src/lib/crypto/cipher_ossl.cpp",
        # Backend version and init (OpenSSL-specific)
        "dist/src/lib/crypto/backend_version.cpp",
        # sha1cd implementation (pure C)
        "dist/src/lib/crypto/sha1cd/sha1.c",
        "dist/src/lib/crypto/sha1cd/ubc_check.c",
    ],
    copts = [
        "-Wno-unused-parameter",
        "-Wno-unused-exception-parameter",
        "-Wno-sign-compare",
        "-Wno-missing-field-initializers",
    ],
    linkopts = select({
        "@platforms//os:linux": ["-lcrypto"],
        "//conditions:default": [],
    }),
    local_defines = [
        "HAVE_CONFIG_H",
        "SHA1DC_FORCE_ALIGNED_ACCESS",
    ],
    target_compatible_with = _RNP_PLATFORM,
    deps = [
        ":rnp_common",
        ":rnp_lib_headers",
        ":rnp_librekey",
        ":rnp_librepgp",
        ":sexpp",
        "//src/third_party/bzip2",
        "//src/third_party/json-c:json_c",
        "@zlib",
    ],
)
